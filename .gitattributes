# 모든 텍스트 파일 LF로 통일
* text=auto eol=lf

# Python
*.py text eol=lf

# 설정 파일
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.toml text eol=lf
Dockerfile text eol=lf

# 바이너리 파일 (줄 종결자 변환 안 함)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pth binary
*.pkl binary
